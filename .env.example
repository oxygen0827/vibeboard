# VibeBoard 前端环境变量模板
#
# 用法：复制本文件为 .env（.env 已被 .gitignore 忽略，不会进版本控制），
# 填入你自己的值。这些变量在 `npm run build` / `npm run dev` 时由 Vite
# 静态注入到前端，作为 Settings 面板的默认连接配置。
#
# 安全提示：
# - 切勿把真实密钥提交进 git。请只写在本地 .env 中。
# - 更安全的做法：把 VITE_DEFAULT_BASE_URL 指向你自建的代理端点，由代理
#   在服务端注入上游真实密钥，这样浏览器永远拿不到真实上游凭证，
#   VITE_DEFAULT_API_KEY 可以留空或填一个仅对代理有效的弱令牌。

# 默认 API Base URL（OpenAI 兼容端点或你的代理）
VITE_DEFAULT_BASE_URL=https://api.openai.com/v1

# 默认模型名
VITE_DEFAULT_MODEL=gpt-4o

# 默认 API Key（留空则要求用户在 Settings 中自行填写）
VITE_DEFAULT_API_KEY=
